---
import Project from "../components/Project.astro";
import StyledButton from "../components/StyledButton.astro";
import Layout from "../layouts/Layout.astro";

import GitHub from "../assets/github.svg";
import Codeberg from "../assets/codeberg.svg";

import Logo from "../assets/spectris.svg";
---

<Layout>
  <main class="p-8 md:p-32 font-display space-y-8 text-white">
    <div class="flex flex-row flex-wrap justify-between text-5xl md:text-7xl  lg:text-8xl gap-8">
      <div class="flex flex-row justify-start items-center">
        <Logo class="max-h-[3em] max-w-[2em] md:max-w-[3em]"/>
        <h1 class="font-semibold">
          <style>@keyframes p{to{background-position:200% center}}</style>

          <span
            class="bg-[linear-gradient(to_right,#ef4444,#f97316,#eab308,#22c55e,#3b82f6,#6366f1,#8b5cf6,#ef4444)] bg-[length:200%_auto] animate-[p_2s_linear_infinite] bg-clip-text text-transparent sm:text-white hover:text-transparent transition-colors duration-1000"
            >Spectris</span
          >
          Collective
        </h1>
      </div>

      <div class="flex flex-row gap-8">
        <a href="https://github.com/seirea" aria-label="Organization GitHub Link">
            <GitHub width=.8em height=.8em class="hover:opacity-50 transition-all" />
        </a>
        <a href="https://codeberg.org/spectris" aria-label="Organization GitHub Link">
            <Codeberg width=.8em height=.8em class="hover:opacity-50 transition-all" />
        </a>
      </div>
    </div>
    
    <div class="space-y-2">
      <h2 class="text-4xl font-medium">About</h2>
      <p class="text-2xl">Spectris is a student software development and research organization.</p>
    </div>

    <div class="space-y-2">
      <h2 class="text-4xl font-medium">Projects</h2>
      <ul class="flex flex-row flex-wrap gap-4">
        <Project
          href="https://app.seirea.org"
          repo_href="https://github.com/Seirea/seirea-web"
          name="Seirea">An open source grade viewer application.</Project
        >
        <Project
          href="https://biomechanics.spectris.dev"
          repo_href="https://github.com/Seirea/biomechanics"
          name="BioMechanics: The Puzzles of Restoration"
          >Puzzle game submission for the U.S. National Science Foundation Game
          Maker Awards Competition.</Project
        >
      </ul>
    </div>
  </main>
</Layout>
